# Ignore sensitive data and temporary files
*.log
*.tmp
auth.json
history.json
sessions/
artifacts/
logs/
.DS_Store
*.swp
*.swo
*~

# Ignore large binary files that don't need versioning
*.pyc
__pycache__/
*.pyo
*.pyd

# Ignore system-specific files
Thumbs.db
*.bak

# Claude sync - exclude session/debug/temp data
claude_sync/debug/
claude_sync/statsig/
claude_sync/cache/
claude_sync/file-history/
